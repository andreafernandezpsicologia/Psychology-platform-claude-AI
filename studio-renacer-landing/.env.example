# Copia este archivo a .env.local para desarrollo local con `vercel dev`
# En producción, configura estas variables en Vercel → Project Settings → Environment Variables

# Obligatorias
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
NOTIFY_TO=info@studiorenacer.com
FROM_EMAIL=Studio Renacer <hola@studiorenacer.com>

# Opcional (si quieres guardar contactos en una audiencia de Resend)
# RESEND_AUDIENCE_ID=00000000-0000-0000-0000-000000000000
